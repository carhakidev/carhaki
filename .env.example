DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Development: use SQLite (default when DATABASE_URL is omitted)
# Production: use PostgreSQL
DATABASE_URL=postgresql://neondb_owner:npg_CWR5kTFZt8uh@ep-winter-breeze-apmxo4di.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require

# Redis (used for caching and Celery task queue)
REDIS_URL=redis://localhost:6379/0

# ==============================================================================
# Email
# ==============================================================================
# Development: console backend is set in development.py automatically
# Production: configure SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=CarHaki <noreply@carhaki.ug>
SERVER_EMAIL=errors@carhaki.ug
ADMIN_EMAIL=admin@carhaki.ug

# ==============================================================================
# USA Vehicle History APIs
# ==============================================================================
# VinAudit - primary USA paid report provider ($1.50-2.00 per report)
# Sign up at: https://www.vinaudit.com/api
VINAUDIT_API_KEY=

# ClearVin - fallback USA provider
# Sign up at: https://www.clearvin.com/api
CLEARVIN_API_KEY=

# ==============================================================================
# ClearVin (USA vehicle history — email + password auth, no API key)
# ==============================================================================
CLEARVIN_EMAIL=your@email.com
CLEARVIN_PASSWORD=your-clearvin-password

# ==============================================================================
# Currency Rate
# ==============================================================================
USD_TO_NGN_RATE=1600

# ==============================================================================
# Anthropic Claude AI (for plain-English report summaries)
# ==============================================================================
# Sign up at: https://console.anthropic.com
# Use claude-haiku-4-5-20251001 for cost-efficient summaries (~$0.003/report)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# Paystack (Nigeria payments: cards, bank transfer, USSD, etc.)
# ==============================================================================
# Sign up at: https://dashboard.paystack.com
# Use test keys for development (prefix: pk_test_ and sk_test_)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==============================================================================
# AWS S3 (optional - for production PDF/media storage)
# ==============================================================================
# Leave blank in development (files stored locally under media/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1

# ==============================================================================
# Site Settings
# ==============================================================================
SITE_URL=http://localhost:8000
SITE_NAME=CarHaki
SITE_TAGLINE=The Truth About Every Car

# Business contact details (used in email footers and contact page)
BUSINESS_ADDRESS=Plot 45, Kampala Road, Kampala, Uganda
BUSINESS_PHONE=+256 700 123 456
BUSINESS_WHATSAPP=256700123456
BUSINESS_EMAIL=info@carhaki.ug
